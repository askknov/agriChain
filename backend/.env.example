# ============================================================
# Backend Environment Variables
# ============================================================

PORT=5000
MONGODB_URI=mongodb://localhost:27017/agrichain

# Blockchain RPC URL (local Hardhat node or Sepolia)
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545

# Server wallet private key for signing blockchain transactions
# Use one of Hardhat's test accounts for local development
SERVER_PRIVATE_KEY=your_private_key_here

# ML Service Configuration
# The ML service runs as a Python Flask microservice on port 8000
# Start it with: cd ml-service && python app.py
ML_API_URL=http://localhost:8000/api/predict
